{
  "name": "chatbot-core-saas",
  "version": "0.1.0",
  "description": "A modular, company-agnostic chatbot widget core package",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "deploy": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
